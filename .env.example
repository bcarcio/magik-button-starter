# Tip: when you mint a key in Local Magik (Settings → API keys), the app shows a
# ready-to-paste block with BOTH lines below already filled in — just copy it here.

# Your API key (starts lmk_):
MAGIK_API_KEY=

# The Local Magik app where you minted the key — this is what the CLI publishes to.
# Hosted on Vercel? Use that URL (e.g. https://your-app.vercel.app), NOT localhost.
# Only use http://localhost:3000 if you're running Local Magik locally.
MAGIK_URL=
